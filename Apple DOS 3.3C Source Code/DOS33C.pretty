                INCLUDE      DOSGOER,,2
                INCLUDE      BLDFTAB,,2
                INCLUDE      CMDTBLS,,2
                INCLUDE      FDOSENT,,2
                INCLUDE      FOPCLRW,,2
                INCLUDE      FDELCAT,,2
                INCLUDE      FMTRWIO,,2
                INCLUDE      FLOCNXB,,2
                INCLUDE      FLOCSEC,,2
                INCLUDE      FVCBUFS,,2
                INCLUDE      BOOTLDR,,2
                INCLUDE      COREQUS,,1
                INCLUDE      PRENIBL,,1
                INCLUDE      WRITRTN,,1
                INCLUDE      POSTNRD,,1
                INCLUDE      RDADSEK,,1
                INCLUDE      MSWAITR,,1
                INCLUDE      WRITADR,,1
                INCLUDE      RWTSONE,,1
                INCLUDE      RWTSTWO,,1
                INCLUDE      FORMATR,,1
                INCLUDE      DOSPTCH,,1

