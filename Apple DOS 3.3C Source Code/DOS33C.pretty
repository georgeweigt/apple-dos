                SBTL         "DOS3.3C w/ APPEND fix, U/L case"
                LST          ON,VSYM
                MSB          OFF
ORIGIN          EQU          $1B00
DIAGMODE        EQU          0
DOS33B          EQU          1
ULC             EQU          0                         ;1=ASM with lower case patch
